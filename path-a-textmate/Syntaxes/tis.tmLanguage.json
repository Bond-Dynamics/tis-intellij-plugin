{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Truth Instruction Set",
  "scopeName": "source.tis",
  "fileTypes": ["tis"],
  "comment": "TIS grammar organized by four primitive types (EXP-001): Entity (noun), Condition (adjective), Coupling (verb), Scope (sentence boundary). ACCUMULATE is the parsing process, not a type.",
  "patterns": [
    { "include": "#comment" },
    { "include": "#det-zero-illegal" },
    { "include": "#jacobian-zero-illegal" },
    { "include": "#det-field" },
    { "include": "#phase-field" },
    { "include": "#kappa-field" },
    { "include": "#rate-field" },
    { "include": "#jacobian-field" },
    { "include": "#tier-field" },
    { "include": "#version-header" },
    { "include": "#scope-anchor" },
    { "include": "#scope-keywords" },
    { "include": "#condition-keywords" },
    { "include": "#coupling-block-keyword" },
    { "include": "#entity-field-keywords" },
    { "include": "#coupling-field-keywords" },
    { "include": "#condition-field-keywords" },
    { "include": "#signal-enum-values" },
    { "include": "#archetype-enum-values" },
    { "include": "#boolean-values" },
    { "include": "#operator-values" },
    { "include": "#string-double" },
    { "include": "#numeric-literal" },
    { "include": "#chain-list-marker" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "match": "(#).*$",
      "name": "comment.line.number-sign.tis",
      "captures": {
        "1": { "name": "punctuation.definition.comment.tis" }
      }
    },

    "det-zero-illegal": {
      "comment": "CRITICAL (Rule L1): det: 0, det: 0.0, det: 0.00 — TYPE ERROR E302. Zero determinant means the composition is decoupled from ground truth.",
      "match": "\\b(det)\\s*(:)\\s*(0(?:\\.0+)?)\\s*(?=$|#|,|\\}|\\s)",
      "captures": {
        "1": { "name": "invalid.illegal.zero-determinant.tis" },
        "2": { "name": "punctuation.separator.key-value.tis" },
        "3": { "name": "invalid.illegal.zero-determinant.tis" }
      }
    },

    "jacobian-zero-illegal": {
      "comment": "Rule L1 extended: jacobian: 0 is also a zero determinant",
      "match": "\\b(jacobian)\\s*(:)\\s*(0(?:\\.0+)?)\\s*(?=$|#|,|\\}|\\s)",
      "captures": {
        "1": { "name": "invalid.illegal.zero-determinant.tis" },
        "2": { "name": "punctuation.separator.key-value.tis" },
        "3": { "name": "invalid.illegal.zero-determinant.tis" }
      }
    },

    "det-field": {
      "comment": "Coupling primitive (verb): det: <nonzero> — valid Jacobian determinant",
      "match": "\\b(det)\\s*(:)\\s*(-?(?:0\\.(?!0+(?:\\s|$|#|,|\\}))[0-9]+|[1-9][0-9]*(?:\\.[0-9]+)?))",
      "captures": {
        "1": { "name": "keyword.operator.coupling.det.tis" },
        "2": { "name": "punctuation.separator.key-value.tis" },
        "3": { "name": "constant.numeric.determinant.tis" }
      }
    },

    "phase-field": {
      "comment": "Coupling primitive (verb): phase: <value> — first-class, not optional metadata. Phase is the only mechanism by which individually valid elements produce invalid composition.",
      "match": "\\b(phase)\\s*(:)\\s*([0-9]+(?:\\.[0-9]+)?)",
      "captures": {
        "1": { "name": "keyword.operator.coupling.phase.tis" },
        "2": { "name": "punctuation.separator.key-value.tis" },
        "3": { "name": "constant.numeric.phase.tis" }
      }
    },

    "kappa-field": {
      "comment": "Coupling primitive (verb): kappa: <value> — condition number",
      "match": "\\b(kappa)\\s*(:)\\s*([0-9]+(?:\\.[0-9]+)?)",
      "captures": {
        "1": { "name": "keyword.operator.coupling.kappa.tis" },
        "2": { "name": "punctuation.separator.key-value.tis" },
        "3": { "name": "constant.numeric.kappa.tis" }
      }
    },

    "rate-field": {
      "comment": "Condition primitive (adjective): rate — entropy processing rate or coupling rate",
      "match": "\\b(rate)\\s*(:)\\s*(-?[0-9]+(?:\\.[0-9]+)?)",
      "captures": {
        "1": { "name": "keyword.other.condition.rate.tis" },
        "2": { "name": "punctuation.separator.key-value.tis" },
        "3": { "name": "constant.numeric.float.tis" }
      }
    },

    "jacobian-field": {
      "comment": "Coupling primitive (verb): jacobian — non-zero Jacobian determinant",
      "match": "\\b(jacobian)\\s*(:)\\s*(-?(?:0\\.(?!0+(?:\\s|$|#|,|\\}))[0-9]+|[1-9][0-9]*(?:\\.[0-9]+)?))",
      "captures": {
        "1": { "name": "keyword.operator.coupling.jacobian.tis" },
        "2": { "name": "punctuation.separator.key-value.tis" },
        "3": { "name": "constant.numeric.determinant.tis" }
      }
    },

    "tier-field": {
      "match": "\\b(tier)\\s*(:)\\s*([0-9]+(?:\\.[0-9]+)?)",
      "captures": {
        "1": { "name": "keyword.other.metadata.tier.tis" },
        "2": { "name": "punctuation.separator.key-value.tis" },
        "3": { "name": "constant.numeric.tier.tis" }
      }
    },

    "version-header": {
      "comment": "tis: \"1.0\" — document version header",
      "match": "^(tis)\\s*(:)\\s*(\"[0-9]+\\.[0-9]+\")",
      "captures": {
        "1": { "name": "keyword.control.version.tis" },
        "2": { "name": "punctuation.separator.key-value.tis" },
        "3": { "name": "string.quoted.double.version.tis" }
      }
    },

    "scope-anchor": {
      "comment": "Scope primitive — ground_truth: the composition anchor. STRONGEST visual weight. It is the C3 anchor that loads first into the composition machine.",
      "match": "^(ground_truth)\\s*(:)",
      "captures": {
        "1": { "name": "keyword.control.scope.anchor.tis markup.bold.tis" },
        "2": { "name": "punctuation.separator.key-value.tis" }
      }
    },

    "scope-keywords": {
      "comment": "Scope primitive (sentence boundary): conditions, chain, metadata — structural delimiters",
      "match": "^(conditions|chain|metadata)\\s*(:)",
      "captures": {
        "1": { "name": "keyword.control.scope.section.tis" },
        "2": { "name": "punctuation.separator.key-value.tis" }
      }
    },

    "condition-keywords": {
      "comment": "Condition primitive (adjective): C1-C4 — composition condition types. Ordering is context-sensitive: C1->C2->C3->C4 follows the acquisition operator.",
      "match": "^\\s+(C1_entropy|C2_coupling|C3_self_modification|C4_closure)\\s*(:)",
      "captures": {
        "1": { "name": "entity.name.type.condition.tis" },
        "2": { "name": "punctuation.separator.key-value.tis" }
      }
    },

    "coupling-block-keyword": {
      "comment": "Coupling primitive (verb): coupling: — declares the coupling relationship",
      "match": "\\b(coupling)\\s*(:)",
      "captures": {
        "1": { "name": "keyword.operator.coupling.block.tis" },
        "2": { "name": "punctuation.separator.key-value.tis" }
      }
    },

    "entity-field-keywords": {
      "comment": "Entity primitive (noun): fields that name or describe entities in the composition",
      "match": "\\b(entity|domain|testable|source|process|target|gradient|protected|notes)\\s*(:)",
      "captures": {
        "1": { "name": "support.type.entity.property.tis" },
        "2": { "name": "punctuation.separator.key-value.tis" }
      }
    },

    "coupling-field-keywords": {
      "comment": "Coupling primitive (verb): fields within coupling and chain link blocks",
      "match": "\\b(to|op|input|output|signal)\\s*(:)",
      "captures": {
        "1": { "name": "support.type.coupling.property.tis" },
        "2": { "name": "punctuation.separator.key-value.tis" }
      }
    },

    "condition-field-keywords": {
      "comment": "Condition primitive (adjective): fields that parameterize conditions",
      "match": "\\b(eigenfunction|eigenvalue|value|min|max|archetype)\\s*(:)",
      "captures": {
        "1": { "name": "support.type.condition.property.tis" },
        "2": { "name": "punctuation.separator.key-value.tis" }
      }
    },

    "signal-enum-values": {
      "comment": "Signal type enum values — map to condition axes",
      "match": "(?<=signal\\s*:\\s*)(entropy|coupling|self_mod|closure)\\b",
      "name": "constant.language.signal.tis"
    },

    "archetype-enum-values": {
      "comment": "Archetype enum values — coupling archetype classification",
      "match": "(?<=archetype\\s*:\\s*)(decoupled|opposed|orthogonal|weak_aligned|strong_aligned|convergent)\\b",
      "name": "constant.language.archetype.tis"
    },

    "boolean-values": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.tis"
    },

    "operator-values": {
      "comment": "Chain operator names — the composition operations (what ACCUMULATE processes)",
      "match": "(?<=op\\s*:\\s*)([A-Z][A-Z0-9_]+)\\b",
      "name": "entity.name.function.operator.tis"
    },

    "string-double": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.tis",
      "patterns": [
        {
          "match": "\\\\[\"\\\\nrt]",
          "name": "constant.character.escape.tis"
        }
      ]
    },

    "numeric-literal": {
      "comment": "Generic numeric literal (catch-all)",
      "match": "(?<=[:\\s,\\[])\\s*(-?[0-9]+(?:\\.[0-9]+)?)\\b",
      "captures": {
        "1": { "name": "constant.numeric.float.tis" }
      }
    },

    "chain-list-marker": {
      "match": "^\\s*(-)(\\s)",
      "captures": {
        "1": { "name": "punctuation.definition.list.begin.tis" },
        "2": { "name": "" }
      }
    },

    "identifier": {
      "comment": "Identifiers used as values (references, entity names)",
      "match": "(?<=[:\\s])([a-z_][a-z0-9_]*)(?=\\s*$|\\s*#)",
      "captures": {
        "1": { "name": "variable.other.reference.tis" }
      }
    }
  }
}
